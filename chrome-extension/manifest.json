{
  "manifest_version": 3,
  "name": "ハイライト英単語帳に追加",
  "version": "1.0.0",
  "description": "選択した英単語をローカルの単語帳アプリ(localhost:8331)へ追加。Optionキー+マウスオーバーで訳を表示。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "notifications"],
  "host_permissions": ["http://localhost:8331/*", "http://127.0.0.1:8331/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
